# --- Python build / cache ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/
*.egg

# --- Virtual env ---
.venv/
venv/
env/

# --- Secrets ---
# .env  intentionally tracked in git (team policy); use private remote if keys inside
.env.local
.env.*.local
configs/override.yaml
secrets/*
!secrets/README.md

# --- IDE ---
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# --- Test / lint caches ---
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/
.hypothesis/

# --- Logs & temp ---
*.log
*.tmp
.tmp_*
*.bak

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Generated at runtime ---
system-state.json

# --- Local runtime data (optional: remove lines to track in git) ---
data/*
!data/.gitkeep
qdrant_data/
postgres_data/
redis_data/

# --- Alembic pycache ---
migrations/versions/__pycache__/
