# =============================================================================
# 与仓库根 .env 同步维护；本仓 .env 纳入 Git（见 .gitignore）
# 优先级：/run/secrets/<file> > 本文件 > configs/override.yaml > default.yaml
# Docker：compose 已配置 env_file 与 ./secrets → /run/secrets:ro
# =============================================================================

# ── 服务 ──
SERVER_HOST=0.0.0.0
SERVER_PORT=6006
SERVER_DEBUG=false
LOGGING_LEVEL=INFO

# ── 数据依赖（本机裸跑）──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_platform
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Docker 内 compose 会覆盖为 postgres/redis/qdrant 主机名，以 compose 为准。

# ── API 认证（F20；开发可 SECURITY_ENABLE_AUTH=false 于 override.yaml）──
# 生产建议：secrets/api_key 文件，或此处留空
SECURITY_API_KEY=

# ── LLM（F04 gateway；与 TestNewHarness 的 TEXT_MODEL__QWEN_API_KEY 等价）──
# 生产建议：secrets/qwen_api_key 文件
TEXT_MODEL__QWEN_API_KEY=
TEXT_MODEL__QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_MODEL__QWEN_MODEL_NAME=qwen-plus
TEXT_MODEL__TEXT_MODEL_PROVIDER=qwen_cloud
TEXT_MODEL__TEXT_VLLM_BASE_URL=http://localhost:8001/v1
TEXT_MODEL__TEXT_VLLM_MODEL=Qwen3.5-9B

# 简写（与上并存，任选其一）
# QWEN_API_KEY=
# VLLM_BASE_URL=http://localhost:8001/v1

# ── JWT（可选）──
# SECURITY__JWT_SECRET=
# 或 secrets/jwt_secret 文件

# ── Prompt 路径 ──
PROMPT_CONFIG__PROMPTS_DIR=./prompts
PROMPT_CONFIG__PROMPTS_DEFAULT_DIR=./prompts/prompts_default
